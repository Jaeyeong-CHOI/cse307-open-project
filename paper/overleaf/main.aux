\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces L4 ablation (PPR = Python Prior Rate). Seven core models: $n=50$ each (5 variants $\times $ 10 runs); \texttt  {gpt-5.4-mini} $n_\mathrm  {eff}=42$ (8 HTTP errors in Var.~E, excluded). Pass rate = 0 for all models. \texttt  {o4-mini} revises $n=20$ preliminary (1/20). $^\S  $E24 frontier extension: \texttt  {gpt-5.4} and \texttt  {o3} also tested at Var.~A, $n=10$: both 0/10 pass, PPR=1.00.}}{7}{}\protected@file@percent }
\newlabel{tab:l4_ablation}{{IV}{7}{}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Prior dominance vs.\ pattern blindness isolated on the same model (\texttt  {gpt-4o}). \textbf  {A}: \texttt  {gpt-4o} correctly inverts logic with explicit rule (L3). \textbf  {B}: The same model reverts to Python prior when the rule is embedded only in examples (L4). This contrast isolates pattern blindness as a failure mode distinct from prior dominance.}}{8}{}\protected@file@percent }
\newlabel{fig:l4_failure}{{4}{8}{}{figure.4}{}}
