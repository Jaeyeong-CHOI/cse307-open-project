\@writefile{lot}{\contentsline {table}{\numberline {III}{\ignorespaces L2--L4 outcomes by model and condition. L2 is trivially adopted by all models (three at $n=20$; \texttt  {gpt-4o-mini} pilot $n=5$); L3 reveals a model-capability threshold (\texttt  {gpt-4o-mini} fails, others succeed); L4 (example-only) defeats all models despite L3 success. Rows with $n=5$ are pilot results; Wilson 95\% CIs shown.}}{6}{}\protected@file@percent }
\newlabel{tab:l234_results}{{III}{6}{}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {V-D}}L4: Pattern blindness across all tested models}{6}{}\protected@file@percent }
\newlabel{sec:l4_ablation}{{\mbox  {V-D}}{6}{}{subsection.5.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces L4 ablation (PPR = Python Prior Rate). All seven models: $n=50$ each (5 variants $\times $ 10 runs). Pass rate = 0/50 for all models. \texttt  {o4-mini} (reasoning model) also achieves 0/50 at $n=50$, revising a preliminary $n=20$ result (1/20).}}{6}{}\protected@file@percent }
\newlabel{tab:l4_ablation}{{IV}{6}{}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Prior dominance vs.\ pattern blindness isolated on the same model (\texttt  {gpt-4o}). \textbf  {A}: \texttt  {gpt-4o} correctly inverts logic with explicit rule (L3). \textbf  {B}: The same model reverts to Python prior when the rule is embedded only in examples (L4). This contrast isolates pattern blindness as a failure mode distinct from prior dominance.}}{6}{}\protected@file@percent }
\newlabel{fig:l4_failure}{{4}{6}{}{figure.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces L4 multi-task summary (\textbf  {345 runs total}). $\dagger $~Partially-annotated prompts; \textbf  {NOT directly comparable to Table~\ref {tab:l4_ablation}}~(strict example-only). Green = pass, red = fail. Dominant failure mode per row in rightmost column. Full PPR values in Appendix~\ref {sec:appendix_l4_multitask_ppr}.}}{7}{}\protected@file@percent }
\newlabel{tab:l4_multitask}{{V}{7}{}{table.5}{}}
