\@writefile{lot}{\contentsline {table}{\numberline {II}{\ignorespaces L1 evaluation: Keyword Leakage Rate (KLR) per model. Baseline rows use $n=120$; ctx-pack rows use $n=20$. Models sorted by KLR (ascending). Context-pack reduces KLR for paired models: \texttt  {gpt-4o-mini} ($-38\%$), \texttt  {gpt-4.1-mini} ($-51\%$). Open-weight models (marked $^\star $) via Groq API, ctx-pack only. PSS (heuristic diagnostic) reported in Appendix~\ref {sec:appendix_pss}.}}{6}{}\protected@file@percent }
\newlabel{tab:l1_results}{{II}{6}{}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces L1 KLR per model (OpenAI models only). Ctx-pack condition shown for all models except \texttt  {gpt-4o} and \texttt  {gpt-5.4-mini} (baseline only; ctx-pack not evaluated). $n{\geq }20$ per bar. Open-weight models (\texttt  {Llama-3.3-70B}, \texttt  {Qwen3-32B}) appear in Table~\ref {tab:l1_results} only; bar chart shows OpenAI models for visual clarity. \textcolor {blue!65}{\rule  {5pt}{5pt}}~\texttt  {gpt-4o} fam.; \textcolor {orange!60}{\rule  {5pt}{5pt}}~\texttt  {gpt-4.1} fam.; \textcolor {green!55!black}{\rule  {5pt}{5pt}}~\texttt  {gpt-5.4-mini} (baseline); \textcolor {violet!60}{\rule  {5pt}{5pt}}~\texttt  {o4-mini}.}}{6}{}\protected@file@percent }
\newlabel{fig:l1_klr_bar}{{3}{6}{}{figure.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {III}{\ignorespaces L2--L4 outcomes by model and condition. L2 is trivially adopted by all models (three at $n=20$; \texttt  {gpt-4o-mini} pilot $n=5$); L3 reveals a model-capability threshold (\texttt  {gpt-4o-mini} fails, others succeed); L4 (example-only) defeats all models despite L3 success. Rows with $n=5$ are pilot results; Wilson 95\% CIs shown.}}{7}{}\protected@file@percent }
\newlabel{tab:l234_results}{{III}{7}{}{table.3}{}}
