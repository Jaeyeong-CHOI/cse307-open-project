\@writefile{lot}{\contentsline {table}{\numberline {II}{\ignorespaces L1 evaluation: KLR and PSS per model. Baseline rows use $n=120$; ctx-pack rows for gpt-4.1 family and o4-mini use $n=20$ (v1--v20 subset). Models sorted by KLR. Context-pack delivery consistently reduces KLR; gpt-4.1-mini ctx-pack achieves the lowest KLR (0.21).}}{4}{}\protected@file@percent }
\newlabel{tab:l1_results}{{II}{4}{}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {III}{\ignorespaces L2--L4 outcomes by model and condition. L2 is trivially adopted; L3 reveals a capability threshold; L4 (example-only delivery) defeats all models, including gpt-4o which succeeds at L3.}}{4}{}\protected@file@percent }
\newlabel{tab:l234_results}{{III}{4}{}{table.3}{}}
