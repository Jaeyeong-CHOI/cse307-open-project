\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces L2 grammar specification as given to the model. Models must produce code using exclusively these constructs. Result: all models fully adopted the syntax (SIR=0.0), showing LLMs readily follow explicit structural rules.}}{7}{}\protected@file@percent }
\newlabel{fig:l2_prompt}{{6}{7}{}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces L3 prompts. The rule is stated explicitly in the system message. Weaker models (gpt-4o-mini) still fail (PPR=1.0), while stronger models succeed---revealing a capability threshold for semantic meta-rule following.}}{7}{}\protected@file@percent }
\newlabel{fig:l3_prompts}{{7}{7}{}{figure.7}{}}
