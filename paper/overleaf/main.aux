\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces L4 ablation (PPR = Python Prior Rate). Seven core models: $n=50$ each (5 variants $\times $ 10 runs); \texttt  {gpt-5.4-mini} $n_\mathrm  {eff}=42$ (8 HTTP errors in Var.~E, excluded). Pass rate = 0 for all models. \texttt  {o4-mini} revises $n=20$ preliminary (1/20). $^\S  $E24 frontier extension: \texttt  {gpt-5.4} and \texttt  {o3} also tested at Var.~A, $n=10$: both 0/10 pass, PPR=1.00.}}{8}{}\protected@file@percent }
