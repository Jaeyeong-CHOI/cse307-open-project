\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces L4 prompt (no system message). The semantic inversion rule is not stated; models must infer it from worked examples. Even gpt-4o, which succeeds at L3, defaults to canonical Python fib---exhibiting \emph  {pattern blindness}.}}{8}{}\protected@file@percent }
\newlabel{fig:l4_prompt}{{8}{8}{}{figure.8}{}}
